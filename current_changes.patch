+}
+
+/* ── Spotify-style progress bar ── */
+.progress-bar-spotify {
+  appearance: none;
+  background: transparent;
+  cursor: pointer;
+}
+
+.progress-bar-spotify::-webkit-slider-runnable-track {
+  height: 4px;
+  background: rgba(255, 255, 255, 0.15);
+  border-radius: 2px;
+}
+
+.progress-bar-spotify::-webkit-slider-thumb {
+  appearance: none;
+  height: 12px;
+  width: 12px;
+  border-radius: 50%;
+  background: #fff;
+  margin-top: -4px;
+  opacity: 0;
+  transition: opacity 0.15s;
+}
+
+.progress-bar-spotify:hover::-webkit-slider-thumb {
+  opacity: 1;
+}
+
+/* ── Ambient glow behind album art ── */
+.ambient-glow {
+  position: absolute;
+  inset: -40%;
+  filter: blur(80px) saturate(2);
+  opacity: 0.3;
+  z-index: -1;
+  transition: opacity 0.6s ease;
+}
+
+/* ── Bounce in ── */
+@keyframes bounce-in {
+  0% {
+    transform: scale(0.3);
+    opacity: 0;
+  }
+
+  50% {
+    transform: scale(1.05);
+  }
+
+  70% {
+    transform: scale(0.95);
+  }
+
+  100% {
+    transform: scale(1);
+    opacity: 1;
+  }
+}
+
+.animate-bounce-in {
+  animation: bounce-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
+}
+
+/* ── Slide up for player ── */
+@keyframes slide-up {
+  from {
+    transform: translateY(100%);
+    opacity: 0;
+  }
+
+  to {
+    transform: translateY(0);
+    opacity: 1;
+  }
+}
+
+.animate-slide-up {
+  animation: slide-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
+}
+
+/* ── Playing bars equalizer ── */
+@keyframes eq-bar {
+
+  0%,
+  100% {
+    height: 30%;
+  }
+
+  50% {
+    height: 100%;
+  }
+}
+
+.eq-bar {
+  display: inline-block;
+  width: 3px;
+  background: var(--color-primary);
+  border-radius: 2px;
+  animation: eq-bar 0.6s ease-in-out infinite;
+}
+
+.eq-bar:nth-child(2) {
+  animation-delay: 0.15s;
+}
+
+.eq-bar:nth-child(3) {
+  animation-delay: 0.3s;
+}
+
+.eq-bar:nth-child(4) {
+  animation-delay: 0.45s;
+}
+
+/* ── Morphing blob ── */
+@keyframes morph-blob {
+
+  0%,
+  100% {
+    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
+  }
+
+  25% {
+    border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
+  }
+
+  50% {
+    border-radius: 50% 60% 30% 60% / 30% 50% 70% 60%;
+  }
+
+  75% {
+    border-radius: 60% 40% 60% 30% / 70% 30% 50% 60%;
+  }
+}
+
+.animate-morph {
+  animation: morph-blob 8s ease-in-out infinite;
+}
+
+/* ── Text reveal ── */
+@keyframes text-reveal {
+  from {
+    clip-path: inset(0 100% 0 0);
+    opacity: 0;
+  }
+
+  to {
+    clip-path: inset(0 0 0 0);
+    opacity: 1;
+  }
+}
+
+.animate-text-reveal {
+  animation: text-reveal 0.8s cubic-bezier(0.65, 0, 0.35, 1) both;
+}
+
+/* ── Equalizer bars (now playing indicator) ── */
+@keyframes eq-bounce {
+
+  0%,
+  100% {
+    height: 3px;
+  }
+
+  50% {
+    height: 12px;
+  }
+}
+
+.eq-bar {
+  display: inline-block;
+  width: 2px;
+  height: 3px;
+  background: var(--color-primary);
+  border-radius: 1px;
+  animation: eq-bounce infinite ease-in-out;
+}
+
+/* ── Radio Wave Pulse ── */
+@keyframes radio-pulse {
+  0% {
+    transform: scale(1);
+    opacity: 0.5;
+  }
+
+  50% {
+    transform: scale(1.5);
+    opacity: 0.2;
+  }
+
+  100% {
+    transform: scale(2);
+    opacity: 0;
+  }
+}
+
+.animate-radio-pulse {
+  position: relative;
+}
+
+.animate-radio-pulse::after {
+  content: '';
+  position: absolute;
+  inset: -8px;
+  border-radius: 50%;
+  border: 1.5px solid var(--color-primary);
+  animation: radio-pulse 2s cubic-bezier(0.24, 0, 0.38, 1) infinite;
+}
+
+/* ── Lyrics Mask ── */
+.lyrics-mask {
+  mask-image: linear-gradient(to bottom,
+      transparent 0%,
+      black 15%,
+      black 85%,
+      transparent 100%);
+  -webkit-mask-image: linear-gradient(to bottom,
+      transparent 0%,
+      black 15%,
+      black 85%,
+      transparent 100%);
+}
+
+/* ── Slow Text Reveal ── */
+@keyframes text-reveal-slow {
+  from {
+    opacity: 0;
+    filter: blur(8px);
+    transform: translateY(10px);
+  }
+
+  to {
+    opacity: 1;
+    filter: blur(0);
+    transform: translateY(0);
+  }
+}
+
+.animate-text-reveal-slow {
+  animation: text-reveal-slow 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
+}
+
+/* ═══════════════════════════════════════════════════════
+   Splash Screen — Premium Logo Animations
+   ═══════════════════════════════════════════════════════ */
+
+/* Ambient glow orbs */
+.splash-glow-orb {
+  position: absolute;
+  border-radius: 50%;
+  filter: blur(100px);
+  opacity: 0.4;
+  animation: splash-float 6s ease-in-out infinite;
+}
+
+.splash-glow-orb-1 {
+  width: 300px;
+  height: 300px;
+  background: radial-gradient(circle, #00FFFF 0%, transparent 70%);
+  top: 30%;
+  left: 35%;
+  animation-delay: 0s;
+}
+
+.splash-glow-orb-2 {
+  width: 200px;
+  height: 200px;
+  background: radial-gradient(circle, #33cccc 0%, transparent 70%);
+  top: 50%;
+  right: 30%;
+  animation-delay: 2s;
+}
+
+.splash-glow-orb-3 {
+  width: 250px;
+  height: 250px;
+  background: radial-gradient(circle, #00cccc 0%, transparent 70%);
+  bottom: 25%;
+  left: 40%;
+  animation-delay: 4s;
+}
+
+@keyframes splash-float {
+  0%, 100% { transform: translate(0, 0) scale(1); }
+  33% { transform: translate(15px, -20px) scale(1.05); }
+  66% { transform: translate(-10px, 10px) scale(0.95); }
+}
+
+/* Pulsing rings around logo */
+.splash-logo-container {
+  position: relative;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+}
+
+.splash-ring {
+  position: absolute;
+  inset: -12px;
+  border-radius: 32px;
+  border: 1.5px solid rgba(0, 255, 255, 0.25);
+  animation: splash-ring-pulse 2s ease-out infinite;
+}
+
+.splash-ring-delay {
+  animation-delay: 1s;
+}
+
+@keyframes splash-ring-pulse {
+  0% {
+    transform: scale(1);
+    opacity: 0.5;
+  }
+  100% {
+    transform: scale(1.5);
+    opacity: 0;
+  }
+}
+
+/* Logo entry animation */
+.splash-logo-icon {
+  animation: splash-logo-enter 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
+}
+
+@keyframes splash-logo-enter {
+  0% {
+    transform: scale(0.5) rotate(-10deg);
+    opacity: 0;
+  }
+  100% {
+    transform: scale(1) rotate(0deg);
+    opacity: 1;
+  }
+}
+
+/* Waveform bars in logo */
+.splash-bar {
+  animation: splash-waveform 1s ease-in-out infinite alternate;
+  transform-origin: center center;
+}
+
+@keyframes splash-waveform {
+  0% { transform: scaleY(0.4); }
+  100% { transform: scaleY(1); }
+}
+
+/* Shimmer wordmark */
+.splash-wordmark {
+  background: linear-gradient(
+    90deg,
+    #ffffff 0%,
+    #00FFFF 25%,
+    #66ffff 50%,
+    #00cccc 75%,
+    #ffffff 100%
+  );
+  background-size: 200% 100%;
+  -webkit-background-clip: text;
+  background-clip: text;
+  -webkit-text-fill-color: transparent;
+  animation: splash-shimmer 2.5s ease-in-out infinite, splash-wordmark-enter 0.6s 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
+}
+
+@keyframes splash-shimmer {
+  0% { background-position: 200% 0; }
+  100% { background-position: -200% 0; }
+}
+
+@keyframes splash-wordmark-enter {
+  0% {
+    opacity: 0;
+    transform: translateY(12px);
+    filter: blur(4px);
+  }
+  100% {
+    opacity: 1;
+    transform: translateY(0);
+    filter: blur(0);
+  }
+}
+
+/* Wave loading bars */
+.splash-wave-bar {
+  animation: splash-wave-bounce 0.8s ease-in-out infinite alternate;
+}
+
+@keyframes splash-wave-bounce {
+  0% { height: 4px; }
+  100% { height: 20px; }
+}
+
+/* Loading ellipsis */
+.loading-ellipsis::after {
+  content: '';
+  animation: loading-dots 1.5s steps(4, end) infinite;
+}
+
+@keyframes loading-dots {
+  0% { content: ''; }
+  25% { content: '.'; }
+  50% { content: '..'; }
+  75% { content: '...'; }
+  100% { content: ''; }
+}
