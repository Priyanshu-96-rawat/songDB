# SongDB — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local with real values.

# ── Last.fm API (SERVER-ONLY) ──
LASTFM_API_KEY=

# ── Firebase Client (NEXT_PUBLIC_ = safe for frontend) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (SERVER-ONLY — never exposed to client) ──
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── YouTube Data API (SERVER-ONLY) ──
YOUTUBE_API_KEY=

# ── Python binary path (for yt-dlp, optional) ──
PYTHON_BIN=python
